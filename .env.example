# Producción / preview: URL pública del API (el navegador debe poder llamarla; CORS en el servidor).
# En desarrollo (npm run dev) no hace falta: las rutas /primetixapi, etc. van por proxy de Vite.
VITE_URL_API=https://testapi.primetix.fun

# Opcional: forzar dominio de reserva / “Ver todos”. Si no se define, se usa el mismo origen del sitio (test vs prod).
# En local, si quieres abrir siempre el Booking de producción:
# VITE_PRIMETIX_WEB_ORIGIN=https://www.primetix.fun

# País para carrusel y eventos (Guatemala = 1). En GitHub Actions no definas la variable vacía:
# una cadena vacía se convertía en 0 y el endpoint ObtieneCarrousel/0 respondía 404.
# VITE_CODIGO_PAIS=1

# Si el hosting NO tiene rewrite SPA (rutas como /login devuelven blanco/404), usa HashRouter.
# VITE_USE_HASH_ROUTER=true

# Recurrente (pasarela checkout en el cliente). No subas valores reales al repositorio.
# En test.primetix.fun / localhost se usan * _TEST o, si no existen, las genéricas sin sufijo.
# En producción (ej. primetix.fun) se usan * _LIVE o las genéricas.
# En GitHub Actions / hosting, inyecta estas variables en el paso de build (secrets).
# VITE_RECURRENTE_PUBLIC_KEY_TEST=pk_test_...
# VITE_RECURRENTE_SECRET_KEY_TEST=sk_test_...
# VITE_RECURRENTE_PUBLIC_KEY_LIVE=pk_live_...
# VITE_RECURRENTE_SECRET_KEY_LIVE=sk_live_...
# Alternativa: una sola pareja para todo el entorno de build:
# VITE_RECURRENTE_PUBLIC_KEY=pk_...
# VITE_RECURRENTE_SECRET_KEY=sk_...

