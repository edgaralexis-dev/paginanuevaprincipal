# Producción / preview: URL pública del API (el navegador debe poder llamarla; CORS en el servidor).
# En desarrollo (npm run dev) no hace falta: las rutas /primetixapi, etc. van por proxy de Vite.
VITE_URL_API=https://testapi.primetix.fun

# Opcional: forzar dominio de reserva / “Ver todos”. Si no se define, se usa el mismo origen del sitio (test vs prod).
# En local, si quieres abrir siempre el Booking de producción:
# VITE_PRIMETIX_WEB_ORIGIN=https://www.primetix.fun

# País para ObtenerEventosAgrupadosPorIdPais (mismo home que paginaprincipal Welcome). Por defecto 1 (Guatemala).
# VITE_CODIGO_PAIS=1

# Si el hosting NO tiene rewrite SPA (rutas como /login devuelven blanco/404), usa HashRouter.
# VITE_USE_HASH_ROUTER=true

